// Type-checks tests and maintenance scripts with the same strictness as src. The build config keeps
// rootDir src, so non-published files use their own noEmit project instead of loosening the build.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src", "test", "scripts"]
}
